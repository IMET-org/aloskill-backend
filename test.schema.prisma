generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Enums
enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  SMART_TV
  GAME_CONSOLE
  UNKNOWN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseType {
  ONLINE
  OFFLINE
  HYBRID
}

enum TeachingApproach {
  INTERACTIVE
  VIDEO
  LIVE
  ASSIGNMENT
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ
  ASSIGNMENT
}

enum NotificationType {
  COURSE_UPDATE
  NEW_MESSAGE
  PAYMENT_SUCCESS
  SYSTEM_ALERT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum TransactionStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  REFUND
  SUBSCRIPTION
}

enum PaymentProviders {
  SSLCommerce
  STRIPE
  PAYPAL
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  MOBILE_WALLET
  BANK_TRANSFER
  OTHER
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum OrderItemStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum InstructorRole {
  PRIMARY
  CO_INSTRUCTOR
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  MULTI_SELECT
}


// === MODELS===//
model User {
  id        String    @id @default(uuid())
  email     String    @unique @db.Text
  password  String?
  avatarUrl String?
  locale    String? // optional locale for notifications / UI
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // === ACCOUNT STATUS=== //
  isEmailVerified Boolean    @default(false)
  status          UserStatus @default(PENDING_VERIFICATION)

  // === EMAIL VERIFICATION ===
  emailVerificationToken   String?
  emailVerificationExpires DateTime?

  // === PASSWORD RESET ===
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // === SOCIAL LOGIN ===
  googleId String? @unique

  // === SECURITY TRACKING ===
  loginAttempts     Int       @default(0)
  lockUntil         DateTime?
  lastLogin         DateTime?
  lastLoginIP       String?
  passwordChangedAt DateTime  @default(now())

  // Role assignments (many)
  roleAssignments UserRoleAssignment[]

  // Profiles
  studentProfile    StudentProfile?
  instructorProfile InstructorProfile?

  // Auth related
  sessions UserSession[]

  // Relations
  enrollments      Enrollment[]         @relation(onDelete: Restrict)
  reviews          Review[]             @relation(onDelete: Restrict)
  payments         PaymentTransaction[] @relation(onDelete: Restrict)
  lessonProgresses LessonProgress[]     @relation(onDelete: Restrict)
  notifications    Notification[]       @relation(onDelete: Cascade)
  wishlists        Wishlist[]           @relation(onDelete: Cascade)
  orders           Order[]              @relation(onDelete: Restrict)

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([emailVerificationToken])
  @@index([passwordResetToken])
}

model UserSession {
  id String @id @default(uuid())

  // User identification
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Device fingerprinting
  deviceId          String
  deviceFingerprint String?

  // Session security
  sessionToken String @unique

  // Device information
  userAgent      String?
  ipAddress      String?
  deviceType     DeviceType
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  platform       String?

  // Location data
  country  String? @db.Char(2)
  city     String?
  region   String?
  timezone String?

  // Session lifecycle
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastActivity DateTime @default(now())

  // Security flags
  isCompromised Boolean   @default(false)
  compromisedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 👇 Relation to RefreshToken
  refreshTokens RefreshToken[] // each rotation belongs here

  // 🔐 Indexes for performance and queries
  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
  @@index([isActive])
  @@index([lastActivity])
  @@index([expiresAt])
  @@index([isCompromised])
  @@index([createdAt])
}

model RefreshToken {
  id        String       @id @default(uuid())
  token     String       @unique
  sessionId String?
  session   UserSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  revoked   Boolean   @default(false)
  revokedAt DateTime?

  replacedByTokenId String?       @unique
  replacedBy        RefreshToken? @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacesToken     RefreshToken? @relation("RefreshTokenRotation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([expiresAt])
  @@index([revoked])
  @@index([revokedAt])
  @@index([replacedByTokenId])
  @@map("refresh_tokens")
}

model UserRoleAssignment {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  role        UserRole
  // metadata 
  grantedById String?
  grantedAt   DateTime @default(now())

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
}

/// Profiles
model StudentProfile {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  displayName String?
  phone       String
  gender      Gender
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([displayName])
}

model InstructorProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  //==Personnal Info
  displayName String
  DOB         String
  gender      Gender
  nationality String

  //== Contact Info
  hashedPhone String //Hashed Data
  address     String
  city        String

  //== Professional Info
  qualifications String
  experience     Decimal @default(0) @db.Decimal(5, 2)
  expertise      String?
  currentOrg     String?

  //== Course Info
  proposedCourse String
  courseLevel    CourseLevel
  courseType     CourseType
  courseInfo     String
  duration       String
  proposedPrice  Decimal     @db.Decimal(10, 2)

  //== Content & Teaching Skills
  teachingExperience   Decimal?         @default(0) @db.Decimal(5, 2)
  prevTeachingApproach TeachingApproach
  language             String
  demoVideo            String?

  //== Others Info
  bio           String?
  skills        Json? // array of strings
  website       String?
  socialAccount SocialLink[]
  paymentId     String? // SSL Connect account id (or other payout id)
  isVerified    Boolean       @default(false)
  ratingAverage Decimal?      @default(0) @db.Decimal(2, 1)
  ratingCount   Int           @default(0)
  totalStudents Int           @default(0)
  totalCourses  Int           @default(0)
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  ownedCourses  Course[]  @relation("CourseOwner",onDelete: Restrict)  
  courseInstructors CourseInstructor[]
  payouts           Payout[]

  @@index([userId])
  @@index([isVerified])
  @@index([ratingAverage])
}

model SocialLink {
  id        String            @id @default(uuid())
  userId    String
  user      InstructorProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  createdAt DateTime          @default(now())
}

/// Courses & content
model Course {
  id            String             @id @default(uuid())
  title         String
  slug          String             @unique
  shortDesc     String?
  description   String?

  // == Pricing == //
  originalPrice    Decimal   @db.Decimal(6, 2)
  discountPercent  Int? @default(0)
  discountPrice    Decimal?  @db.Decimal(6, 2)
  discountEndDate  DateTime?
  isDiscountActive Boolean   @default(false)
  currency         String?   @default("BDT")

  status        CourseStatus       @default(DRAFT)
  language      String?
  thumbnailUrl  String?

  categoryId    String?
  category      Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById   String? // instructorProfile id (nullable if system-created)
  createdBy     InstructorProfile? @relation("CourseOwner", fields: [createdById], references: [id], onDelete: SetNull)
  modules       Module[]
  enrollments   Enrollment[]       @relation(onDelete: Restrict)
  reviews       Review[]           @relation(onDelete: Restrict)
  tags          CourseTag[]
  wishlistedBy  Wishlist[]

  ratingAverage Decimal?           @default(0) @db.Decimal(2, 1)
  ratingCount   Int                @default(0)
  metadata      Json?
  deletedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  courseInstructors CourseInstructor[]

  @@index([createdById])
  @@index([slug])
  @@index([status])
  @@index([originalPrice])
  @@index([ratingAverage])
  @@index([categoryId])
  @@index([createdAt])
}

model CourseInstructor {
  id           String            @id @default(uuid())
  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId     String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  instructorId String
  role         InstructorRole?
  assignedAt   DateTime          @default(now())

  @@unique([courseId, instructorId])
  @@index([courseId])
  @@index([instructorId])
}

/// Module & Lesson
model Module {
  id        String    @id @default(uuid())
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  title     String
  position  Int
  deletedAt DateTime?
  lessons   Lesson[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([courseId])
  @@index([courseId, position])
}

model Lesson {
  id         String     @id @default(uuid())
  module     Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  title      String
  content    String? // summary or HTML
  type       LessonType
  contentUrl String?
  duration   Int? // seconds
  position   Int
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  progressRecords  LessonProgress[]
  discussions      LessonDiscussion[] @relation(onDelete: Cascade)
  quizzes          Quiz[]

  @@index([moduleId])
  @@index([moduleId, position])
}

model LessonDiscussion {
  id String @id @default(uuid())
  // Relations
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId String

  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdById String

  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments LessonComment[]

  // 🧠 Indexes
  @@index([lessonId])
  @@index([createdById])
  @@index([lessonId, createdAt])
}

model LessonComment {
  id String @id @default(uuid())

  // Relations
  discussion   LessonDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  discussionId String

  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)
  authorId String

  parentComment   LessonComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  parentCommentId String?
  replies         LessonComment[] @relation("CommentReplies")

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isEdited  Boolean @default(false)
  isDeleted Boolean @default(false)

  // 🧠 Indexes
  @@index([discussionId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([discussionId, createdAt])
}

/// Enrollment & progress
model Enrollment {
  id          String    @id @default(uuid())

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId      String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseId    String

  pricePaid   Decimal?  @db.Decimal(6, 2)
  currency    String   @default("BDT")
  status      EnrollmentStatus    @default(ACTIVE)
  progress    Decimal?  @default(0) @db.Decimal(5, 2)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  deletedAt   DateTime?
  updatedAt   DateTime  @updatedAt

  certificate Certificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([startedAt])
}

model LessonProgress {
  id           String    @id @default(uuid())

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId       String
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId     String
  courseId     String
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Restrict)

  completed    Boolean   @default(false)
  progressValue Int      @default(0) // for video resume (seconds)
  lastViewedAt DateTime?
  attempts     Int?      @default(0) // e.g., quiz attempts
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([courseId])
  @@index([completed])
  @@index([updatedAt])
  @@index([userId, courseId])
}

/// Reviews & ratings
model Review {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId    String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseId  String
  rating    Int @default(0)
  title     String?
  body      String?
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([rating])
  @@index([createdAt])
}

//=== WISH LIST ===//
model Wishlist {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

//== ORDER ==//
model Order {
  id                  String               @id @default(uuid())
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId              String
  totalAmount         Decimal @db.Decimal(10, 2)
  currency            String               @default("BDT")
  status              OrderStatus          @default(PENDING)
  provider            PaymentProviders?
  providerOrderId     String?
  paymentTransactions PaymentTransaction[]
  orderItems          OrderItem[]
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([totalAmount])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())

  // Relations
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseId  String

  price     Decimal  @db.Decimal(10, 2)
  currency  String?  @default("BDT")
  status    OrderItemStatus   @default(PENDING)
  createdAt DateTime @default(now())

  @@unique([orderId, courseId])
  @@index([orderId])
  @@index([courseId])
}

/// Payments & payouts
model PaymentTransaction {
  id                String   @id @default(uuid())

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId            String
  course            Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId          String?
  order             Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId           String?

  paymentMethod     PaymentMethod?
  providerFee       Decimal? @db.Decimal(10, 2)
  providerTransactionId  String?  @unique

  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("BDT")
  provider          PaymentProviders
  providerPaymentId String?  @unique
  cardType          String?
  cardNumber        String?
  cardHolderName    String?
  status            TransactionStatus
  type              TransactionType?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([createdAt])
}

model Payout {
  id               String            @id @default(uuid())

  // Relations
  instructor       InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Restrict)
  instructorId     String

  amount           Decimal  @db.Decimal(10, 2)
  fee              Decimal? @db.Decimal(10, 2)
  payoutDate       DateTime
  providerPayoutId String?  @unique
  status           PaymentStatus
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([instructorId])
  @@index([status])
  @@index([payoutDate])
}

/// Categories & tags
model Category {
  id       String   @id @default(uuid())
  name     String   @unique
  slug     String   @unique
  parentId String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  courses  Course[]

  @@index([slug])
  @@index([name])
  @@index([parentId])
}

model Tag {
  id      String      @id @default(uuid())
  name    String      @unique
  slug    String      @unique
  courses CourseTag[]

  @@index([slug])
  @@index([name])
}

model CourseTag {
  id       String @id @default(uuid())

  // Relations
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId    String

  @@unique([courseId, tagId])
  @@index([courseId])
  @@index([tagId])
}

/// Certificate
model Certificate {
  id             String     @id @default(uuid())
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId   String     @unique
  issuedAt       DateTime   @default(now())
  certificateUrl String
  verified       Boolean    @default(false)

  @@index([issuedAt])
}

/// Notifications & audit
model Notification {
  id        String           @id @default(uuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  message   String?
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType])
  @@index([createdAt])
}

// Quizzes
model Quiz {
  id                String          @id @default(uuid())
  lesson            Lesson?         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId          String?
  title             String
  description       String?
  
  // Quiz Rules
  duration          Int?
  passingScore      Decimal         @default(70) @db.Decimal(5, 2)
  attemptsAllowed   Int             @default(1)
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Inverse Relations
  questions         QuizQuestion[]
  results           QuizResult[]

  @@index([lessonId])
}

model QuizQuestion {
  id                String          @id @default(uuid())
  quiz              Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId            String
  
  text              String
  type              QuestionType
  points            Int             @default(1)
  position          Int
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  //Relations
  options           QuestionOption[]

  @@index([quizId])
  @@index([quizId, position])
}

model QuestionOption {
  id                String          @id @default(uuid())
  question          QuizQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId        String
  
  text              String
  isCorrect         Boolean         @default(false)
  // Used only if QuestionType is SHORT_ANSWER (e.g., 'Paris' vs 'paris')
  exactMatchAnswer  String?         
  createdAt         DateTime        @default(now())

  @@index([questionId])
}

model QuizResult {
  id                String          @id @default(uuid())

  // Relations
  quiz              Quiz            @relation(fields: [quizId], references: [id], onDelete: Restrict)
  quizId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId            String
  
  scoreAchieved     Decimal         @default(0) @db.Decimal(5, 2)
  isPassed          Boolean         @default(false)
  submissionData    Json?           
  
  startedAt         DateTime        @default(now())
  submittedAt       DateTime?
  
  @@index([quizId, userId])
  @@index([userId, isPassed])
  @@index([submittedAt])
}

/// Generic activity/event table for analytics
model ActivityEvent {
  id        String   @id @default(uuid())
  userId    String?
  courseId  String?
  lessonId  String?
  eventType String // "view:lesson", "start:course", "complete:lesson"
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([courseId])
  @@index([lessonId])
  @@index([eventType])
}
