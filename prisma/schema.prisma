generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Enums
enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  SMART_TV
  GAME_CONSOLE
  UNKNOWN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseType {
  LIVE
  PRE_RECORDED
  HYBRID
  SELF_STUDY
}

enum Language {
  ENGLISH
  BANGLA
}

enum CourseCategory {
  BUSINESS
  MARKETING
  ENTREPRENEURSHIP
  ICT
}

enum TeachingApproach {
  INTERACTIVE
  VIDEO
  LIVE
  PROJECT_BASED
}

enum TeachingLanguage {
  ENGLISH
  BANGLA
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ
  ASSIGNMENT
}

enum NotificationType {
  COURSE_UPDATE
  NEW_MESSAGE
  PAYMENT_SUCCESS
  SYSTEM_ALERT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum TransactionStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  REFUND
  SUBSCRIPTION
}

enum PaymentProviders {
  SSLCommerce
  STRIPE
  PAYPAL
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  MOBILE_WALLET
  BANK_TRANSFER
  OTHER
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum OrderItemStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum InstructorRole {
  PRIMARY
  CO_INSTRUCTOR
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  MULTI_SELECT
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SocialPlatform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  LINKEDIN
  YOUTUBE
}

// === MODELS===//
model User {
  id        String    @id @default(uuid())
  email     String    @unique @db.VarChar(254)
  password  String?
  avatarUrl String?
  locale    String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // === ACCOUNT STATUS=== //
  isEmailVerified Boolean    @default(false)
  status          UserStatus @default(PENDING_VERIFICATION)

  // === EMAIL VERIFICATION ===
  emailVerificationTokenHash String?
  emailVerificationExpires   DateTime?

  // === PASSWORD RESET ===
  passwordResetTokenHash String?
  passwordResetExpires   DateTime?

  // === SOCIAL LOGIN ===
  googleId String? @unique

  // === SECURITY TRACKING ===
  loginAttempts     Int       @default(0)
  failedLoginAt     DateTime?
  lockUntil         DateTime?
  lastLogin         DateTime?
  lastLoginIP       String?
  lastActivityAt    DateTime?
  passwordChangedAt DateTime  @default(now())

  // Role assignments (many)
  assignedRole UserRoleAssignment[]

  // Profiles
  studentProfile    StudentProfile?
  instructorProfile InstructorProfile?

  // Counts
  enrollmentCount   Int @default(0)
  reviewCount       Int @default(0)
  paymentCount      Int @default(0)
  notificationCount Int @default(0)
  orderCount        Int @default(0)
  progressesCount   Int @default(0)
  wishlistsCount    Int @default(0)

  // Auth related
  sessions UserSession[]

  // Others Relations
  enrollments      Enrollment[]
  reviews          Review[]
  payments         PaymentTransaction[]
  lessonProgresses LessonProgress[]
  notifications    Notification[]
  wishlists        Wishlist[]
  orders           Order[]
  LessonDiscussion LessonDiscussion[]
  LessonComment    LessonComment[]
  QuizResult       QuizResult[]
  AuditLog         AuditLog[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([emailVerificationTokenHash])
  @@index([passwordResetTokenHash])
}

model UserSession {
  id String @id @default(uuid())

  // User identification
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Device fingerprinting
  deviceId          String
  deviceFingerprint String?

  // Session security
  sessionToken String @unique

  // Device information
  userAgent      String?
  ipAddress      String?
  deviceType     DeviceType
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  platform       String?

  // Location data
  country     String? @db.Char(2)
  city        String?
  region      String?
  timezone    String?
  geoLocation Json?

  // Session lifecycle
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastActivity DateTime @default(now())

  // Security flags
  isCompromised   Boolean   @default(false)
  compromisedAt   DateTime?
  suspicious      Boolean   @default(false)
  suspiciousSince DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 👇 Relation to RefreshToken
  refreshTokens RefreshToken[]

  // Indexes
  @@unique([userId, deviceId])
  @@index([deviceId])
  @@index([isActive])
  @@index([expiresAt])
  @@index([isCompromised])
  @@index([createdAt])
}

model RefreshToken {
  id        String       @id @default(uuid())
  token     String       @unique
  sessionId String?
  session   UserSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  revoked   Boolean   @default(false)
  revokedAt DateTime?

  replacedByTokenId String?       @unique
  replacedBy        RefreshToken? @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacesToken     RefreshToken? @relation("RefreshTokenRotation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([expiresAt])
  @@index([revoked])
  @@index([revokedAt])
  @@index([replacedByTokenId])
  @@map("refresh_tokens")
}

model UserRoleAssignment {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  role        UserRole
  // metadata
  grantedById String?
  grantedAt   DateTime @default(now())

  @@unique([userId, role])
  @@index([userId, role])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique // e.g., "course:create", "user:suspend", "payout:view"
  description String?
  roles       RolePermission[]

  @@index([name])
}

model RolePermission {
  id   String   @id @default(uuid())
  role UserRole

  // The action (e.g., course:create)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
}

/// Profiles
model StudentProfile {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String    @unique
  displayName    String
  encryptedPhone String
  phoneLastFour  String    @db.Char(4)
  gender         Gender
  bio            String?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([displayName])
}

model InstructorProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  //==Personnal Info
  displayName String
  DOB         DateTime
  gender      Gender
  nationality String

  //== Contact Info
  encryptedPhone String
  phoneLastFour  String @db.Char(4)
  address        String @db.VarChar(255)
  city           String @db.VarChar(20)

  //== Professional Info
  qualifications String
  experience     Int     @default(0) @db.SmallInt()
  expertise      String?
  currentOrg     String?

  //== Course Info
  proposedCourseCategory CourseCategory
  courseLevel            CourseLevel
  courseType             CourseType

  //== Content & Teaching Skills
  teachingExperience   Decimal?         @default(0) @db.Decimal(5, 2)
  prevTeachingApproach TeachingApproach
  language             TeachingLanguage
  demoVideo            String?

  //== Others Info
  bio                String
  skills             InstructorSkill[]
  website            String?
  socialAccount      SocialLink[]
  paymentId          String? // SSL Connect account id (or other payout id)
  status             ApplicationStatus @default(PENDING)
  rejectionReason    String?
  ratingAverage      Decimal?          @default(0) @db.Decimal(2, 1)
  ratingCount        Int               @default(0)
  totalStudents      Int               @default(0)
  totalCourses       Int               @default(0)
  totalRevenueAmount Decimal           @default(0) @db.Decimal(15, 2)
  totalRefunds       Decimal           @default(0) @db.Decimal(15, 2)

  deletedAt      DateTime?
  deletionReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  ownedCourses      Course[]           @relation("CourseOwner")
  courseInstructors CourseInstructor[]
  payouts           Payout[]

  @@index([userId])
  @@index([status])
  @@index([ratingAverage])
  @@index([deletedAt])
  @@index([userId, status, deletedAt])
}

model InstructorSkill {
  id           String            @id @default(uuid())
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  instructorId String
  skill        String

  @@unique([instructorId, skill])
}

model SocialLink {
  id        String            @id @default(uuid())
  userId    String
  user      InstructorProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  SocialPlatform
  url       String
  createdAt DateTime          @default(now())
}

/// Courses & content
model Course {
  id          String @id @default(uuid())
  title       String
  slug        String @unique
  description String

  // == Pricing == //
  originalPrice    Decimal   @db.Decimal(6, 2)
  discountPercent  Int?      @default(0)
  discountPrice    Decimal?  @db.Decimal(6, 2)
  discountEndDate  DateTime?
  isDiscountActive Boolean   @default(false)
  currency         String?   @default("BDT")

  enrollmentCount    Int     @default(0)
  reviewCount        Int     @default(0)
  totalRevenueAmount Decimal @default(0) @db.Decimal(12, 2)
  moduleCount        Int     @default(0)

  status       CourseStatus @default(DRAFT)
  language     Language     @default(BANGLA)
  level        CourseLevel  @default(BEGINNER)
  thumbnailUrl String?

  categoryId  String?
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   InstructorProfile? @relation("CourseOwner", fields: [createdById], references: [id], onDelete: SetNull)

  ratingAverage Decimal?  @default(0) @db.Decimal(2, 1)
  ratingCount   Int       @default(0)
  views         Int       @default(0)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  courseInstructors  CourseInstructor[]
  LessonProgress     LessonProgress[]
  PaymentTransaction PaymentTransaction[]
  OrderItem          OrderItem[]
  modules            Module[]
  enrollments        Enrollment[]
  reviews            Review[]
  tags               CourseTag[]
  wishlistedBy       Wishlist[]

  @@index([slug])
  @@index([status])
  @@index([originalPrice])
  @@index([enrollmentCount])
  @@index([ratingAverage])
  @@index([categoryId])
  @@index([createdById, status, deletedAt, createdAt])
}

model CourseInstructor {
  id           String            @id @default(uuid())
  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId     String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  instructorId String
  role         InstructorRole?
  assignedAt   DateTime          @default(now())

  @@unique([courseId, instructorId])
  @@index([courseId])
  @@index([instructorId])
}

/// Module & Lesson
model Module {
  id        String    @id @default(uuid())
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  position  Int
  title     String
  deletedAt DateTime?
  lessons   Lesson[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([courseId])
  @@index([courseId, position])
}

model Lesson {
  id         String     @id @default(uuid())
  module     Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  position   Int
  title      String
  description String
  notes      String?
  type       LessonType
  contentUrl String?
  files      String[]
  duration   Int?
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  progressRecords LessonProgress[]
  discussions     LessonDiscussion[]
  quizzes         Quiz[]

  @@index([moduleId])
  @@index([moduleId, position])
}

model LessonDiscussion {
  id       String @id @default(uuid())
  // Relations
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId String

  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdById String

  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  comments LessonComment[]

  // 🧠 Indexes
  @@index([lessonId])
  @@index([createdById])
  @@index([lessonId, createdAt])
}

model LessonComment {
  id String @id @default(uuid())

  // Relations
  discussion   LessonDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  discussionId String

  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)
  authorId String

  parentComment   LessonComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  parentCommentId String?
  replies         LessonComment[] @relation("CommentReplies")

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isEdited  Boolean @default(false)
  isDeleted Boolean @default(false)

  deletedAt DateTime?

  // 🧠 Indexes
  @@index([discussionId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([discussionId, createdAt])
}

/// Enrollment & progress
model Enrollment {
  id       String @id @default(uuid())
  // Relations
  user     User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId   String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseId String

  pricePaid           Decimal?         @db.Decimal(6, 2)
  originalPriceAtTime Decimal          @db.Decimal(6, 2)
  discountAtTime      Int              @default(0)
  currency            String           @default("BDT")
  status              EnrollmentStatus @default(ACTIVE)
  refundedAt          DateTime?
  refundAmount        Decimal?
  refundReason        String?
  progress            Decimal?         @default(0) @db.Decimal(5, 2)
  startedAt           DateTime         @default(now())
  completedAt         DateTime?
  deletedAt           DateTime?
  updatedAt           DateTime         @updatedAt

  certificate Certificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([startedAt])
  @@index([status, startedAt])
}

model LessonProgress {
  id       String @id @default(uuid())
  // Relations
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  completed     Boolean   @default(false)
  progressValue Int       @default(0)
  lastViewedAt  DateTime?
  attempts      Int?      @default(0)
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([courseId])
  @@index([completed])
  @@index([userId, courseId])
  @@index([userId, completed, updatedAt])
}

/// Reviews & ratings
model Review {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId    String
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  rating    Int       @default(0)
  title     String?
  body      String?
  flagged   Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([rating])
  @@index([createdAt])
  @@index([courseId, rating, createdAt])
}

//=== WISH LIST ===//
model Wishlist {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

//== ORDER ==//
model Order {
  id                  String               @id @default(uuid())
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId              String
  totalAmount         Decimal              @db.Decimal(10, 2)
  currency            String               @default("BDT")
  status              OrderStatus          @default(PENDING)
  provider            PaymentProviders?
  providerOrderId     String?
  paymentTransactions PaymentTransaction[]
  orderItems          OrderItem[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([userId, createdAt, status])
  @@index([totalAmount])
}

model OrderItem {
  id       String @id @default(uuid())
  // Relations
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId  String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseId String

  price     Decimal         @db.Decimal(10, 2)
  currency  String?         @default("BDT")
  status    OrderItemStatus @default(PENDING)
  createdAt DateTime        @default(now())

  @@unique([orderId, courseId])
  @@index([orderId])
  @@index([courseId])
}

/// Payments & payouts
model PaymentTransaction {
  id       String  @id @default(uuid())
  // Relations
  user     User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId   String
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId String?
  order    Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId  String?

  paymentMethod         PaymentMethod?
  providerFee           Decimal?       @db.Decimal(6, 2)
  providerTransactionId String?        @unique

  amount            Decimal           @db.Decimal(10, 2)
  currency          String            @default("BDT")
  provider          PaymentProviders
  providerPaymentId String?           @unique
  status            TransactionStatus
  type              TransactionType?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@index([courseId])
  @@index([userId, status, createdAt])
}

model Payout {
  id           String            @id @default(uuid())
  // Relations
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Restrict)
  instructorId String

  amount           Decimal       @db.Decimal(10, 2)
  fee              Decimal?      @db.Decimal(10, 2)
  currency         String        @default("BDT")
  payoutDate       DateTime
  providerPayoutId String?       @unique
  status           PaymentStatus

  // Audit trail
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?

  // Retry tracking
  failureReason String?
  retryCount    Int       @default(0)
  nextRetryAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([instructorId])
  @@index([status])
  @@index([payoutDate])
  @@index([instructorId, status])
  @@index([status, payoutDate])
}

/// Categories & tags
model Category {
  id       String  @id @default(uuid())
  name     String  @unique
  slug     String  @unique
  parentId String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  courses Course[]

  @@index([slug])
  @@index([name])
  @@index([parentId])
}

model Tag {
  id      String      @id @default(uuid())
  name    String      @unique
  slug    String      @unique
  courses CourseTag[]

  @@index([slug])
  @@index([name])
}

model CourseTag {
  id       String @id @default(uuid())
  // Relations
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId    String

  @@unique([courseId, tagId])
  @@index([courseId])
  @@index([tagId])
}

/// Certificate
model Certificate {
  id              String     @id @default(uuid())
  enrollment      Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId    String     @unique
  certificateUrl  String
  certificateHash String     @unique

  issuedAt  DateTime  @default(now())
  expiresAt DateTime?

  verified   Boolean   @default(false)
  verifiedBy String?
  verifiedAt DateTime?

  revoked       Boolean   @default(false)
  revokedReason String?
  revokedAt     DateTime?

  @@index([issuedAt])
}

/// Notifications & audit
model Notification {
  id         String           @id @default(uuid())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       NotificationType
  title      String
  message    String?
  isRead     Boolean          @default(false)
  isArchived Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId, isRead, isArchived])
  @@index([userId, isArchived, createdAt])
  @@index([createdAt])
}

// Quizzes
model Quiz {
  id          String  @id @default(uuid())
  lesson      Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String?
  title       String
  description String?

  // Quiz Rules
  duration        Int?
  passingScore    Decimal @db.Decimal(3, 2)
  attemptsAllowed Int     @default(1) @db.SmallInt()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Inverse Relations
  questions QuizQuestion[]
  results   QuizResult[]

  @@index([lessonId])
}

model QuizQuestion {
  id     String @id @default(uuid())
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId String

  text     String
  type     QuestionType
  points   Int          @default(1)
  position Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Relations
  options QuestionOption[]

  @@index([quizId])
  @@index([quizId, position])
}

model QuestionOption {
  id         String       @id @default(uuid())
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String

  text             String
  isCorrect        Boolean  @default(false)
  // Used only if QuestionType is SHORT_ANSWER (e.g., 'Paris' vs 'paris')
  exactMatchAnswer String?
  createdAt        DateTime @default(now())

  @@index([questionId])
}

model QuizResult {
  id     String @id @default(uuid())
  // Relations
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId String

  scoreAchieved  Decimal @default(0) @db.Decimal(5, 2)
  isPassed       Boolean @default(false)
  submissionData Json?

  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  @@index([quizId, userId])
  @@index([userId, isPassed])
  @@index([submittedAt])
}

model AuditLog {
  id     String @id @default(uuid())
  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // What changed?
  action     String // "enroll_created", "course_published"
  entityType String // "course", "enrollment", "payout"
  entityId   String // "course_123"

  // Before & After
  changesBefore Json?
  changesAfter  Json? // { price: 80 }

  // Context
  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@index([entityType, entityId, timestamp])
  @@index([action, timestamp])
}

// === BASIC PLATFORM SETTINGS ===
model PlatformSettings {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // === PLATFORM INFO ===
  platformName String  @default("Aloskill")
  logo         String?
  favicon      String?
  contactEmail String?
  supportPhone String?

  // === EMAIL SETTINGS (for verification/reset emails) ===
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPassword String?

  // === BASIC SETTINGS ===
  maintenanceMode  Boolean @default(false)
  registrationOpen Boolean @default(true)

  @@map("platform_settings")
}
